
# PUSTORA ADMIN PANEL - ENV CONFIGURATION TEMPLATE
# Copy this file to '.env.local' and fill in your private server values.

# 1. PUBLIC SUPABASE CREDENTIALS (Client-side Queries)
# Standard public URL of the Supabase project instance.
NEXT_PUBLIC_SUPABASE_URL="https://your-supabase-project-id.supabase.co"

# Standard public anon key.
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-supabase-anon-key-content"

# 2. PRIVATE SERVER SUPABASE BYPASS KEY (Server Actions / Server Components)
# CRITICAL: This is the service role secret key. It bypasses RLS policies entirely.
# NEVER expose this key in client-side code, `.env` file, or frontend network calls.
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-supabase-private-service-role-secret-key"

# 3. RAZORPAY PRIVATE GATEWAY SECRET (Server Verification)
# Used on the server-side to verify Razorpay signature webhooks.
RAZORPAY_KEY_SECRET="your_razorpay_merchant_private_api_secret_key"
