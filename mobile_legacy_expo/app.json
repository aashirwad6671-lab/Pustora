{
  "expo": {
    "name": "Pustora",
    "slug": "pustora",
    "version": "1.0.0",
    "scheme": "pustora",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
