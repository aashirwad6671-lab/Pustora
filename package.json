{
  "name": "pustora-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": {
    "packages": [
      "admin",
      "customer"
    ]
  },
  "scripts": {
    "admin:dev": "npm run dev --workspace=admin",
    "admin:build": "npm run build --workspace=admin",
    "mobile:start": "npm run start --prefix mobile",
    "mobile:android": "npm run android --prefix mobile",
    "mobile:ios": "npm run ios --prefix mobile",
    "mobile:web": "npm run web --prefix mobile",
    "customer:dev": "npm run dev --workspace=customer",
    "customer:build": "npm run build --workspace=customer",
    "install:deps": "npm install --legacy-peer-deps",
    "install:mobile": "npm install --prefix mobile --legacy-peer-deps"
  }
}

